{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "NEXTAUTH_URL": "https://vant-fx.biz",
    "TELEGRAM_BOT_TOKEN": "7822980872:AAFg-ORc2h-Y4rMZ6UUGfiWx8ZsekUTiIYs",
    "TELEGRAM_CHAT_ID": "8046767319",
    "VERCEL": "1"
  },
  "headers": [
    {
      "source": "/api/(.*)",
